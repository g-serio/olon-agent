import { z } from 'zod';
import { BaseSectionSettingsSchema } from '@/lib/base-schemas';
import { MySchema } from './schema';
export type MyData     = z.infer<typeof MySchema>;
export type MySettings = z.infer<typeof BaseSectionSettingsSchema>;
```

